<Publish>
	<!--Id must be set in order to update existed mod. it is not required for publishing mod for the first time-->
	<ModId Value="" />
	<!--Name of the mod to display to players-->
	<DisplayName Value="TownRoadLane" />
	<!--Short description of the mod-->
	<ShortDescription Value="Adds edge-side road markings to vanilla city roads (3m lanes)" />
	<!--Long description of the mod. Single line or multi line. Supports minimal markdown subset-->
	<!--LongDescription Value="Makes the game generate proper edge lane markings for ordinary city roads with 3m lanes, the same way highway roads get them, so parking, sidewalks and stops react correctly." /-->
	<LongDescription>
Makes the game generate proper edge lane markings for ordinary city roads with 3m lanes, the same way highway roads get them, so parking, sidewalks and stops react correctly.
	</LongDescription>
	<!--Thumbnail-->
	<Thumbnail Value="Properties/Thumbnail.png" />
	<!--Screenshot, can be set multiple times-->
	<Screenshot Value="" />
	<!--Tag, can be set multiple times-->
	<Tag Value="" />
	<!--Link to the forum post where the mod can be discussed-->
	<ForumLink Value="" />
	<!--Version of the mod-->
	<ModVersion Value="1.0" />
	<!--Recommended version of the base game to use the mod-->
	<GameVersion Value="1.0.*" />
	<!--Dependency for the mod, can be set multiple times.
	    Both G87 packs supply the render prefabs our styles reference:
	    97828 = [G87] Road Markings (includes UK Set)  - line styles, junction box, bike/bus fills
	    98624 = [G87] Road Markings: Stripes and Chevrons - stripe area fills
	    The mod degrades gracefully without them (vanilla/concrete fallbacks), but every
	    non-default style needs them, so they ship as hard deps for install-and-it-works.-->
	<Dependency Id="97828" />
	<Dependency Id="98624" />
	<!--Required DLC, can be set multiple times. Supported values are "Landmark Buildings", "San Fransisco Set", "Beach Properties", "Urban Promenades", "Modern Architecture"-->
	<RequiredDLC Value="" />
	<!--Change log for new version. Single line or multi line. Supports minimal markdown subset-->
	<ChangeLog Value="" />
	<!--<ChangeLog>
	</ChangeLog>-->
	<!--External link, can be set multiple times. supported types are "discord", "github", "youtube", "twitch", "x", "paypal", "patreon", "buymeacoffee", "kofi", "crowdin", "gitlab", "gofundme"-->
	<ExternalLink Type="" Url="" />
	<!--Supported values Public, Private, Unlisted-->
	<AccessLevel Value="Public" />
</Publish>
